{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "type": "remote",
      "enabled": true
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://llama:8080/v1"
      },
      "models": {
        "qwen": {
          "name": "Qwen",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  }
}
